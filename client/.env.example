# Azure AD app registration used for delegated user sign-in (MSAL).
# Requires a "Single-page application" platform with the redirect URI below
# and the "User.Read" delegated permission (default, no admin consent needed).
#
# When VITE_AZURE_CLIENT_ID / VITE_AZURE_TENANT_ID are left empty, the app
# falls back to a static "Tenant: Contoso Corp" badge and no sign-in UI.
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
VITE_AZURE_REDIRECT_URI=http://localhost:5173

# Base URL of the provisioning API (server/).
VITE_API_BASE_URL=http://localhost:3001
